NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# Postgres
DATABASE_URL=postgresql://pantry:pantry@localhost:5432/pantry?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=change-me-32-bytes-minimum-aaaaaaa
JWT_ACCESS_TTL_SECONDS=900
JWT_ISSUER=pantry-api
JWT_AUDIENCE=pantry-app
REFRESH_TOKEN_TTL_DAYS=30
TOTP_ENCRYPTION_KEY=change-me-32-bytes-base64

# Rate limiting (per 1-minute window)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_USER_PER_MIN=60
RATE_LIMIT_PER_IP_PER_MIN=30
RATE_LIMIT_AUTH_PER_IP_PER_MIN=10

# OAuth
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=

# WebAuthn
# WEBAUTHN_RP_ID must be a real domain that serves Digital Asset Links / AASA
# (for production: typically the public API host, e.g. api.example.com).
# `localhost` only works for browser WebAuthn on the same machine — Android/
# iOS platform passkeys reject it.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Expyrico
WEBAUTHN_ORIGIN=http://localhost:8081
# Optional comma-separated extra origins accepted at verify time.
# Android native: android:apk-key-hash:<base64url-sha256-of-signing-cert>
# WEBAUTHN_ADDITIONAL_ORIGINS=android:apk-key-hash:REPLACE_ME
# Optional: publish /.well-known/assetlinks.json from the API for Android passkeys
ANDROID_PACKAGE_NAME=com.expyrico.app
# ANDROID_SHA256_CERT_FINGERPRINTS=AA:BB:CC:...

# SMTP (for verification + reset emails)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Pantry <no-reply@pantry.local>"

# Frontend URLs (used in email links)
APP_DEEP_LINK=expyrico://
ADMIN_URL=http://localhost:4001

# Country detection
COUNTRY_DETECT_PRIMARY=https://ipapi.co
COUNTRY_DETECT_FALLBACK=http://ip-api.com

# Firebase Cloud Messaging — project ID is public; runtime credentials use ADC.
# service_account_file requires GOOGLE_APPLICATION_CREDENTIALS to point at an ignored JSON file.
FIREBASE_PROJECT_ID=expyrico-example
FIREBASE_CREDENTIAL_MODE=workload_identity
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase-service-account.json

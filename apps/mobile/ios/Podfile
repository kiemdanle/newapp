# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, '16.0'
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'Expyrico' do
  use_modular_headers!
  config = use_native_modules!

  # WatermelonDB's podspec requires the NPM-vendored @nozbe/simdjson pod.
  pod 'simdjson', :path => '../../../node_modules/@nozbe/simdjson'

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'ExpyricoTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |bc|
        bc.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
      end
    end

    # fmt 11.0.2 (RN 0.76) enables consteval on modern Apple clang, which then
    # fails format-inl.h compile-time checks. Disable consteval in the vendored
    # header after every pod install.
    fmt_base = File.join(__dir__, 'Pods/fmt/include/fmt/base.h')
    if File.exist?(fmt_base)
      contents = File.read(fmt_base)
      patched = contents.gsub(
        /#elif defined\(__cpp_consteval\)\n#  define FMT_USE_CONSTEVAL 1/,
        "#elif defined(__cpp_consteval)\n#  define FMT_USE_CONSTEVAL 0  // patched: Apple clang consteval broken with fmt 11.0.2"
      ).gsub(
        /#elif FMT_GCC_VERSION >= 1002 \|\| FMT_CLANG_VERSION >= 1101\n#  define FMT_USE_CONSTEVAL 1/,
        "#elif FMT_GCC_VERSION >= 1002 || FMT_CLANG_VERSION >= 1101\n#  define FMT_USE_CONSTEVAL 0  // patched: Apple clang consteval broken with fmt 11.0.2"
      )
      File.write(fmt_base, patched) if patched != contents
    end
  end
end

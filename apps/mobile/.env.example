# Example environment variables for apps/mobile.
# Copy this file to .env and fill in real values from your secrets manager.
# Values here are PUBLIC build-time constants; never put API keys, tokens, or
# signing material in this file.

# Public API host (use a reserved .invalid host for local development)
API_BASE_URL=https://api.expyrico.invalid

# Firebase / Google Sign-In public client IDs
GOOGLE_WEB_CLIENT_ID=000000000000-abcdefghijklmnopqrstuvwxyz.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=000000000000-abcdefghijklmnopqrstuvwxyz.apps.googleusercontent.com

# Passkey relying-party identifier (must match API WEBAUTHN_RP_ID and the
# domain that serves /.well-known/assetlinks.json / AASA). Placeholder
# `.invalid` domains cannot create platform passkeys.
PASSKEY_RP_ID=expyrico.invalid

# Android package for deep-link verification (public)
ANDROID_PACKAGE_NAME=com.expyrico.app
